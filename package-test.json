{
  "name": "sweet-layers-testing",
  "version": "1.0.0",
  "description": "Testing suite for Sweet Layers e-commerce platform",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "test:quick": "playwright test --grep 'Homepage|Customizer'",
    "test:mobile": "playwright test --grep 'Mobile'",
    "test:performance": "playwright test --grep 'Performance'",
    "install:browsers": "playwright install"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@playwright/test-reporter": "^1.1.0",
    "playwright": "^1.40.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
